__r("a9f4b1").extend({"shared.loading":"Loading...","payouts.payout_preferences.loading":"Loading","host_estimate.search_results_a11y":"Results updated","review_understanding.pdp.summarized_by_ai":"Summarised by AI","shared.Learn_more":"Learn more","review_understanding.pdp.review_summaries_legal_disclaimer_button_a11y_label":"Learn more about review summaries","review_understanding.pdp.review_tags_legal_disclaimer_button_a11y_label":"Learn more about review tags","review_understanding.pdp.review_summaries_legal_disclaimer_title":"How review summaries work","review_understanding.pdp.review_tags_legal_disclaimer_title":"How review tags work","review_understanding.pdp.review_summaries_legal_disclaimer":"We use AI to find and summarise guest reviews about each topic. Summaries are based on reviews from the past 4 years, which are sorted by recency. AI may not always get things right, so please verify important information in the reviews.","review_understanding.pdp.review_tags_legal_disclaimer":"We use AI to find guest reviews about each topic. Reviews are sorted by recency.\n\nFor now, tags are only available for reviews written in English, Spanish, French, Portuguese, German, Italian and Chinese. This means there could be other reviews about this topic that aren’t shown here.","review_understanding.pdp.review_tag_count":"%{smart_count} review||||%{smart_count} reviews","px_feedback_calendar_prompt_ask_for_feedback":"Give us feedback","review_understanding.pdp.eap_feedback_title":"Give feedback","review_understanding.pdp.eap_feedback_subtitle":"Was the AI summary helpful? Tell us what you liked and if anything could be improved.","pdp.reviews.response.disclaimer.translated":"Translated","pdp.reviews.translation_button.is_translated.cta":"Show original","pdp.reviews.translate_to_langauge":"Translate to %{language}","merlin.pdp_sections.reviews.overall_ratings":"Overall rating","pdp.reviews.based_on_reviews":"Based on %{smart_count} review||||Based on %{smart_count} reviews","pdp.reviews.detailed_ratings_title":"Detailed ratings","pdp.reviews.detailed_ratings_subtitle":"Guests leave a rating for each category","pdp.reviews.accessibility_label.rating":"Rating, %{smart_count} star||||Rating, %{smart_count} stars","pdp.reviews.show_full_ratings":"Show full ratings","pdp_platform.luxe.review_from_luxury_retreats":"Review from Luxury Retreats, part of the Airbnb family","pdp_platform.shared.superhost_badge_label":"%{name} is a Superhost.","pdp_platform.homes.reviews_section.response_from":"Response from %{name}","merlin.pdp_sections.show_more_copy":"Show more","review_understanding.pdp.review_tags_carousel.title":"Guest reviews mention","china.pdp.destination.review_tag.ALL":"All reviews","shared.Close":"Close","ios.host_profile_picture.18a74818":"Host profile picture","shared.Previous":"Previous","shared.Next":"Next","feedback_widget.Modal for feedback to be submitted":"Modal for feedback to be submitted","pdp.reviews.review_tags_show_more":"Show more","pdp.reviews.review_tags_show_less":"Show less","merlin.pdp_sections.title.reviews_label":"Rated %{rating} out of %{total} from %{smart_count} review.|||| Rated %{rating} out of %{total} from %{smart_count} reviews.","merlin.pdp_sections.title.few_reviews":"%{smart_count} review||||%{smart_count} reviews","merlin.pdp_sections.title.new_status":"New","merlin.pdp_sections.reviews.stays.global_region.disclaimer.tooltip_title":"How reviews work","merlin.pdp_sections.policies.learn_more_copy":"Learn more","merlin.pdp_sections.reviews.stays.global_region.4_year_look_back.disclaimer.modal_text":"Reviews from past guests help our community learn more about each home. By default, reviews are sorted by relevance. Relevance is based on recency, length and information that you provide to us, such as your booking search, your country and your language preferences.\n\nOnly the guest who made the reservation can leave a review, and Airbnb only moderates reviews flagged for not following our policies.\n\nTo be eligible for a percentile ranking or guest favourite label, listings need at least 5 reviews in the last 4 years. Criteria are subject to change.\n\n%{link_start}Learn more in our Help Centre%{link_end}","merlin.pdp_sections.reviews.stays.au_region.disclaimer.modal_title":"How reviews and rankings work","m13_pdp.reviews_sort_accessibility_label":"Ratings sort order","merlin.pdp_sections.reviews.see_all_reviews_button_copy":"Show all %{smart_count} review||||Show all %{smart_count} reviews","merlin.pdp_sections.reviews.show_all_review_details":"Show all review details","shared.opens_modal_dialog":"Opens modal dialog","pdp.reviews.top_quality_score_heading_subtitle":"This home is in the <b>top %{percentage}%</b> of eligible listings based on ratings, reviews and reliability","pdp.reviews.guest_favorite_heading_subtitle":"This home is a guest favourite based on ratings, reviews and reliability","pdp.reviews.bottom_quality_score_heading_subtitle":"This home is in the <b>bottom 10%</b> of eligible listings based on ratings, reviews and reliability","p3.summary.number of stars and reviews":"%{num_stars} out of 5 stars from %{num_reviews} reviews","merlin.reviews.no_rating_title":"No rating yet","merlin.pdp_sections.reviews.subtitle.average_rating":"Average rating will appear after %{smart_count} review||||Average rating will appear after %{smart_count} reviews","merlin.reviews.guest_favorite_heading_title":"Guest favourite","shared.reviews with smart count":"%{smart_count} review||||%{smart_count} reviews","pdp.reviews.empty_category_rating_disclaimer":"Detailed ratings will appear once more guests have reviewed this place.","shared.next":"Next"});
